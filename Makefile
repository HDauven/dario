ZK_BROWSER_WASM := zk_browser/build/dash/dash_zk_js/dash_zk.wasm
ZK_BROWSER_ZKEY := zk_browser/build/dash/dash_zk_final.zkey
ZK_BROWSER_ARTIFACT_TAG := zk-browser-v1
ZK_BROWSER_ARTIFACT_URL := https://github.com/HDauven/dario/releases/download/$(ZK_BROWSER_ARTIFACT_TAG)
ZK_BROWSER_WASM_SHA256 := fb3908202b44ae3062f95e4261c30d69d8d514d586731b1f33cf9a95ab46fe48
ZK_BROWSER_ZKEY_SHA256 := dd5d6f37db89880d461e2ddc9c99cadb48b46bd6e10e91bb83c5529d4819c5fa
ZK_BROWSER_PTAU := zk_browser/ptau/powersOfTau28_hez_final_19.ptau
ZK_BROWSER_PTAU_SHA256 := 3f428d1a407e4704ef906960e000b03089e5e6ec29bf65b07bb5e3de005f4700

contract: ## Build contract
	@RUSTFLAGS="-C link-args=-zstack-size=65536" \
	cargo build \
	  --release \
	  --manifest-path=contract/Cargo.toml \
	  --color=always \
	  -Z build-std=core,alloc \
	  --target wasm32-unknown-unknown \
	  --features contract
	@mkdir -p target/stripped
	@find target/wasm32-unknown-unknown/release -maxdepth 1 -name "*.wasm" \
	    | xargs -I % basename % \
	    | xargs -I % wasm-tools strip -a \
	 	          target/wasm32-unknown-unknown/release/% \
	 	          -o target/stripped/%

moonlight-router: ## Build test-only Moonlight router
	@RUSTFLAGS="-C link-args=-zstack-size=65536" \
	cargo build \
	  --release \
	  --manifest-path=moonlight_router/Cargo.toml \
	  --color=always \
	  -Z build-std=core,alloc \
	  --target wasm32-unknown-unknown \
	  --features contract
	@mkdir -p target/stripped
	@wasm-tools strip -a \
	  target/wasm32-unknown-unknown/release/moonlight_router.wasm \
	  -o target/stripped/moonlight_router.wasm

data-driver: ## Build data-driver (generated by #[contract] macro)
	@cargo build \
	  --release \
	  --manifest-path=contract/Cargo.toml \
	  --color=always \
	  --target wasm32-unknown-unknown \
	  --features data-driver-js
	@mkdir -p target/stripped
	@cp target/wasm32-unknown-unknown/release/contract.wasm target/stripped/data_driver.wasm
	@wasm-tools strip -a target/stripped/data_driver.wasm -o target/stripped/data_driver.wasm
	@echo "Data-driver WASM: target/stripped/data_driver.wasm"

web-assets: data-driver ## Copy generated data-driver into the web app
	@npm --prefix web run prepare:driver

zk-browser-artifacts: ## Download and verify the canonical browser proving artifacts when missing
	@mkdir -p $(dir $(ZK_BROWSER_WASM))
	@if test -f $(ZK_BROWSER_WASM); then \
	  printf '%s  %s\n' $(ZK_BROWSER_WASM_SHA256) $(ZK_BROWSER_WASM) | sha256sum --check --status || \
	    { echo "$(ZK_BROWSER_WASM) does not match the pinned artifact" >&2; exit 1; }; \
	else \
	  curl --fail --location --retry 3 -o $(ZK_BROWSER_WASM).tmp \
	    $(ZK_BROWSER_ARTIFACT_URL)/dash_zk.wasm; \
	  printf '%s  %s\n' $(ZK_BROWSER_WASM_SHA256) $(ZK_BROWSER_WASM).tmp | sha256sum --check --status; \
	  mv $(ZK_BROWSER_WASM).tmp $(ZK_BROWSER_WASM); \
	fi
	@if test -f $(ZK_BROWSER_ZKEY); then \
	  printf '%s  %s\n' $(ZK_BROWSER_ZKEY_SHA256) $(ZK_BROWSER_ZKEY) | sha256sum --check --status || \
	    { echo "$(ZK_BROWSER_ZKEY) does not match the pinned artifact" >&2; exit 1; }; \
	else \
	  curl --fail --location --retry 3 -o $(ZK_BROWSER_ZKEY).tmp \
	    $(ZK_BROWSER_ARTIFACT_URL)/dash_zk_final.zkey; \
	  printf '%s  %s\n' $(ZK_BROWSER_ZKEY_SHA256) $(ZK_BROWSER_ZKEY).tmp | sha256sum --check --status; \
	  mv $(ZK_BROWSER_ZKEY).tmp $(ZK_BROWSER_ZKEY); \
	fi

zk-browser-ptau: ## Download and verify the phase-1 powers-of-tau file when missing
	@mkdir -p $(dir $(ZK_BROWSER_PTAU))
	@if ! printf '%s  %s\n' $(ZK_BROWSER_PTAU_SHA256) $(ZK_BROWSER_PTAU) | sha256sum --check --status 2>/dev/null; then \
	  rm -f $(ZK_BROWSER_PTAU) $(ZK_BROWSER_PTAU).tmp; \
	  curl --fail --location --retry 3 -o $(ZK_BROWSER_PTAU).tmp \
	    https://storage.googleapis.com/zkevm/ptau/powersOfTau28_hez_final_19.ptau; \
	  printf '%s  %s\n' $(ZK_BROWSER_PTAU_SHA256) $(ZK_BROWSER_PTAU).tmp | sha256sum --check --status; \
	  mv $(ZK_BROWSER_PTAU).tmp $(ZK_BROWSER_PTAU); \
	fi

zk-assets: zk-browser-artifacts ## Copy canonical circom wasm + proving key into the web app
	@mkdir -p web/public/zk
	@cp $(ZK_BROWSER_WASM) web/public/zk/dash_zk.wasm
	@cp $(ZK_BROWSER_ZKEY) web/public/zk/dash_zk_final.zkey
	@echo "ZK artifacts copied to web/public/zk/"

zk-browser-setup: zk-browser-ptau ## Compile the circuit and create fresh Groth16 keys (needs circom; downloads ~580MB ptau once)
	@cd zk_browser && npm ci
	@mkdir -p zk_browser/build/dash
	@cd zk_browser && circom circuits/dash_zk.circom --r1cs --wasm -o build/dash -l node_modules
	@cd zk_browser && node --max-old-space-size=8192 node_modules/.bin/snarkjs groth16 setup \
	  build/dash/dash_zk.r1cs ptau/powersOfTau28_hez_final_19.ptau build/dash/dash_zk_0000.zkey
	@cd zk_browser && node node_modules/.bin/snarkjs zkey contribute \
	  build/dash/dash_zk_0000.zkey build/dash/dash_zk_final.zkey --name="dario" -e="dario dash entropy"
	@cd zk_browser && node node_modules/.bin/snarkjs zkey export verificationkey \
	  build/dash/dash_zk_final.zkey build/dash/vkey.json
	@cd zk && cargo run --release -p dash-prover -- export-snarkjs-vkey \
	  ../zk_browser/build/dash/vkey.json ../contract/assets dash_zk
	@echo "Circuit + keys ready. Run 'make zk-assets' and rebuild the contract."

dash-web: ## Build the deterministic sim to wasm for the web app
	@wasm-pack build dash_web \
	  --target web \
	  --release \
	  --no-typescript \
	  --out-dir ../web/src/dash-wasm

web: web-assets dash-web zk-assets ## Run the web app locally
	@npm --prefix web install
	@npm --prefix web run dev

web-build: web-assets dash-web zk-assets ## Build the web app
	@npm --prefix web ci
	@npm --prefix web run build

zk: ## Build the RISC Zero guest and prover CLI (separate workspace)
	@cd zk && cargo build --release

zk-constants: zk ## Regenerate contract verification constants from the guest
	@cd zk && ./target/release/dash-prover export-constants ../contract/assets

# Usage: make prove RUN=run.json OUT=bundle.json
prove: zk ## Prove a recorded run (requires x86 + Docker for Groth16 wrap)
	@cd zk && ./target/release/dash-prover prove $(abspath $(RUN)) $(abspath $(OUT))

test: contract moonlight-router ## Run all tests
	@cargo test \
	  --manifest-path=tests/Cargo.toml \
	  --all-features \
	  --color=always
	@cargo test \
	  --manifest-path=dario_fsm/Cargo.toml \
	  --color=always
	@cargo test \
	  --manifest-path=dash_core/Cargo.toml \
	  --color=always
	@cargo test \
	  --manifest-path=dash_zk/Cargo.toml \
	  --color=always

.PHONY: contract moonlight-router data-driver web-assets zk-assets zk-browser-artifacts zk-browser-ptau zk-browser-setup dash-web web web-build zk zk-constants prove test
